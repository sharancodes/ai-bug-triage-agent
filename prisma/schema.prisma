// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id             String       @id @default(cuid())
  rootCause      String       @db.Text
  reason         String       @db.Text
  confidence     Int
  severity       String
  priority       String
  estimatedTime  String?      @db.Text
  risk           String?       @db.Text
  suggestedFix   String?       @db.Text
  similarTickets String?       @db.Text
  jiraPreview    String?       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  jiraTicket     JiraTicket?
}

model JiraTicket {
  id          String   @id @default(cuid())
  key         String   @unique
  analysisId  String   @unique
  project     String
  issueType   String
  summary     String   @db.Text
  description String?  @db.Text
  priority    String
  labels      String?
  components  String?
  assignee    String?
  epic        String?
  storyPoints Int?
  environment String?
  attachments String?
  status      String   @default("Created")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  analysis    Analysis? @relation(fields: [analysisId], references: [id])
}

model Settings {
  id               Int     @id @default(1)
  jiraUrl          String?
  jiraEmail        String?
  jiraApiToken     String?
  defaultProject   String?
  defaultSprint    String?
  defaultLabels    String?
  defaultComponents String?
  defaultAssignee  String?
  // OpenRouter AI
  openRouterApiKey String?
  openRouterModel  String?
  // Advanced toggles
  autoCreateTickets  Boolean @default(false)
  includeReasoning   Boolean @default(true)
  duplicateDetection  Boolean @default(true)
  attachRawLogs      Boolean @default(true)
  notifyAssignee     Boolean @default(true)
  updatedAt          DateTime @updatedAt
}
